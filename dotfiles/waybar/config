{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "pulseaudio",
    "battery",
    "cpu",
    "memory",
    "temperature",
    "network",
    "tray",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "on-click": "activate",
    "sort-by": "number",
    "format": "{icon}",
    "format-icons": {
      "1": "Y",
      "2": "U",
      "3": "I",
      "4": "O",
      "5": "P"
    },
    "persistent-workspaces": {
      "DSI-1": [1, 2, 3, 4, 5]
    }
  },

  "clock": {
    "format": "{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "{:%A, %Y-%m-%d\nWeek: %V}"
  },

  "battery": {
    "bat": "BAT0",
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "ůįāĄ",
    "format-icons": ["ÔČĄ", "ÔČÉ", "ÔČā", "ÔČĀ", "ÔČÄ"],
    "tooltip": true,
    "tooltip-format": "Battery: {capacity}%"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "ůįĚü",
    "format-icons": {
      "headphone": ["ůįčč"],
      "default": ["ůįēŅ", "ůįĖÄ", "ůįēĺ"]
    },
    "states": {
      "overamplified": 101
    },
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%",
    "scroll-step": 2
  },

  "cpu": {
    "interval": 2,
    "format": "{icon}",
    "format-icons": ["‚ĖĀ", "‚Ėā", "‚ĖÉ", "‚ĖĄ", "‚ĖÖ", "‚ĖÜ", "‚Ėá", "‚Ėą"],
    "states": {
      "warning": 60,
      "critical": 85
    },
    "tooltip": true
  },

  "memory": {
    "interval": 5,
    "format": "{icon}",
    "format-icons": ["‚ĖĀ", "‚Ėā", "‚ĖÉ", "‚ĖĄ", "‚ĖÖ", "‚ĖÜ", "‚Ėá", "‚Ėą"],
    "states": {
      "warning": 75,
      "critical": 90
    },
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)"
  },

  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "interval": 5,
    "warning-threshold": 75,
    "critical-threshold": 90,
    "format": "ÔčČ",
    "format-warning": "Ôčą",
    "format-critical": "Ôčá",
    "tooltip": true,
    "tooltip-format": "CPU: {temperatureC}¬įC"
  },

  "network": {
    "format-wifi": "{icon}",
    "format-icons": {
      "wifi": [
        "ůį§ü",
        "ůį§Ę",
        "ůį§•",
        "ůį§®",
        "Ôáę"
      ]
    },
    "format-ethernet": "ůįąĀ",
    "format-disconnected": "ÔĄß",
    "tooltip": true,
    "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 6
  },

  "custom/power": {
    "format": "ÔÄĎ",
    "exec": "echo 'ÔÄĎ'",
    "interval": 0,
    "tooltip": true,
    "tooltip-format": "Logout / Reboot / Shutdown",
    "on-click": "~/.config/waybar/scripts/powermenu.sh"
  }
}

