{
  "layer": "top",
  "position": "top",

  "modules-left": [
    "hyprland/workspaces"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "pulseaudio",
    "battery",
    "cpu",
    "memory",
    "temperature",
    "network",
    "tray",
    "custom/power"
  ],

  "hyprland/workspaces": {
    "on-click": "activate",
    "sort-by": "number",
    "format": "{icon}",
    "format-icons": {
      "1": "Y",
      "2": "U",
      "3": "I",
      "4": "O",
      "5": "P"
    },
    "persistent-workspaces": {
      "DSI-1": [1, 2, 3, 4, 5]
    }
  },

  "clock": {
    "on-click": "gsimplecal",
    "format": "{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "{:%A, %Y-%m-%d\nWeek: %V}"
  },

  "battery": {
    "on-click": "~/.config/waybar/scripts/module-info.sh battery",
    "on-click-right": "~/.config/waybar/scripts/popup.sh btop",
    "bat": "BAT0",
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-charging": "у°‚„",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "tooltip": true,
    "tooltip-format": "Battery: {capacity}%"
  },

  "pulseaudio": {
    "on-click": "~/.config/waybar/scripts/module-info.sh volume",
    "on-click-right": "~/.config/waybar/scripts/popup.sh --gui org.pulseaudio.pavucontrol pavucontrol",
    "format": "{icon}",
    "format-muted": "у°ќџ",
    "format-icons": {
      "headphone": ["у°‹‹"],
      "default": ["у°•ї", "у°–Ђ", "у°•ѕ"]
    },
    "states": {
      "overamplified": 101
    },
    "tooltip": true,
    "tooltip-format": "Volume: {volume}%",
    "scroll-step": 2
  },

  "cpu": {
    "on-click": "~/.config/waybar/scripts/module-info.sh cpu",
    "on-click-right": "~/.config/waybar/scripts/popup.sh btop",
    "interval": 2,
    "format": "{icon}",
    "format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"],
    "states": {
      "warning": 60,
      "critical": 85
    },
    "tooltip": true
  },

  "memory": {
    "on-click": "~/.config/waybar/scripts/module-info.sh memory",
    "on-click-right": "~/.config/waybar/scripts/popup.sh btop",
    "interval": 5,
    "format": "{icon}",
    "format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"],
    "states": {
      "warning": 75,
      "critical": 90
    },
    "tooltip": true,
    "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)"
  },

  "temperature": {
    "on-click": "~/.config/waybar/scripts/module-info.sh temperature",
    "on-click-right": "~/.config/waybar/scripts/popup.sh btop",
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "interval": 5,
    "warning-threshold": 75,
    "critical-threshold": 90,
    "format": "п‹‰",
    "format-warning": "п‹€",
    "format-critical": "п‹‡",
    "tooltip": true,
    "tooltip-format": "CPU: {temperatureC}В°C"
  },

  "network": {
    "on-click": "~/.config/waybar/scripts/module-info.sh network",
    "on-click-right": "~/.config/waybar/scripts/popup.sh nmtui",
    "format-wifi": "{icon}",
    "format-icons": {
      "wifi": [
        "у°¤џ",
        "у°¤ў",
        "у°¤Ґ",
        "у°¤Ё",
        "п‡«"
      ]
    },
    "format-ethernet": "у°€Ѓ",
    "format-disconnected": "п„§",
    "tooltip": true,
    "tooltip-format": "SSID: {essid}\nSignal: {signalStrength}%"
  },

  "tray": {
    "icon-size": 20,
    "spacing": 6
  },

  "custom/power": {
    "format": "пЂ‘",
    "exec": "echo 'пЂ‘'",
    "interval": 0,
    "tooltip": true,
    "tooltip-format": "Logout / Reboot / Shutdown",
    "on-click": "~/.config/waybar/scripts/powermenu.sh"
  }
}

